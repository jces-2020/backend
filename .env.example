# Credenciales de Mercado Pago
# ========================================
# Obtén tus credenciales en: https://www.mercadopago.com.ar/developers/panel/app
#
# Para desarrollo: Usa credenciales de PRUEBA (TEST-xxxxx)
# Para producción: Usa credenciales reales (APP_USR-xxxxx)

# Access Token (PRIVADO - nunca compartir)
MERCADO_PAGO_ACCESS_TOKEN=TEST-1412542350445034-011500-d6f20366d5ae9b143e38bba9d53ff7b2-3135079821

# Public Key (PÚBLICO - se usa en el frontend si usas Checkout Transparente)
# MERCADO_PAGO_PUBLIC_KEY=TEST-dfb34bd8-a2a0-42b0-86d7-9b7ad185e78f

# Webhook Secret (para validar firmas HMAC)
# Se genera automáticamente en el panel al configurar webhooks
# MERCADO_PAGO_WEBHOOK_SECRET=tu_clave_secreta_aqui

# Ambiente (development o production)
ENVIRONMENT=development
